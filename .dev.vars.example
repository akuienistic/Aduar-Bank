## Cloudflare dev vars (local only)
## Copy to `.dev.vars` and fill values. `.dev.vars` is gitignored.

# SMTP config (Gmail App Password recommended)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=

# Sender shown in outgoing emails (usually the same as SMTP_USER)
# Example: MAIL_FROM="Aduar Bank <yourgmail@gmail.com>"
MAIL_FROM=

# Optional: used for tagging/logging
SITE_URL=http://localhost:5173

